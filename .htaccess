# Enable rewrite engine
RewriteEngine On

# Remove .html extension and redirect to clean URLs (EXCEPT /blog/)
# Example: /page.html → /page/
RewriteCond %{REQUEST_URI} !^/blog/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)\.html$ /$1/ [R=301,L]

# If a .html file exists, redirect to directory version (EXCEPT /blog/)
RewriteCond %{REQUEST_URI} !^/blog/
RewriteCond %{REQUEST_URI} \.html$
RewriteRule ^(.*)\.html$ /$1/ [R=301,L]

# Ensure trailing slash for directories (EXCEPT /blog/ .html files)
RewriteCond %{REQUEST_URI} !^/blog/.*\.html$
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !(.*)/$
RewriteRule ^(.*)$ /$1/ [R=301,L]

# Handle directory index files
DirectoryIndex index.html

# Force HTTPS (optional but recommended)
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} ^banglaaiguide\.com$ [OR]
RewriteCond %{HTTP_HOST} ^www\.banglaaiguide\.com$
RewriteRule ^(.*)$ https://banglaaiguide.com/$1 [R=301,L]

# Remove www (optional - redirects www to non-www)
RewriteCond %{HTTP_HOST} ^www\.banglaaiguide\.com$ [NC]
RewriteRule ^(.*)$ https://banglaaiguide.com/$1 [R=301,L]
