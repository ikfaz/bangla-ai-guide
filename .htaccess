# Enable rewrite engine
RewriteEngine On

# ============================================================
# 1. Legacy URL 301 redirects
#    Listed FIRST with absolute https:// targets so that HTTP,
#    www, and HTTPS entry points all land in a single hop —
#    no HTTP→HTTPS→legacy chain.
# ============================================================

# /index.html → /
RewriteRule ^index\.html$ https://banglaaiguide.com/ [R=301,L]

# /tool-detail.html?tool=stable-diffusion → /stable-diffusion/
RewriteCond %{QUERY_STRING} ^tool=stable-diffusion
RewriteRule ^tool-detail\.html$ https://banglaaiguide.com/stable-diffusion/? [R=301,L]

# /tool-detail.html?tool=huggingchat → /huggingchat/
RewriteCond %{QUERY_STRING} ^tool=huggingchat
RewriteRule ^tool-detail\.html$ https://banglaaiguide.com/huggingchat/? [R=301,L]

# /tool-detail.html?tool=meta-ai → /meta-ai/
RewriteCond %{QUERY_STRING} ^tool=meta-ai
RewriteRule ^tool-detail\.html$ https://banglaaiguide.com/meta-ai/? [R=301,L]

# /elevenlabs-bangla-voice/privacy.html → /elevenlabs/
RewriteRule ^elevenlabs-bangla-voice/privacy\.html$ https://banglaaiguide.com/elevenlabs/ [R=301,L]

# /elevenlabs/privacy.html → /elevenlabs/
RewriteRule ^elevenlabs/privacy\.html$ https://banglaaiguide.com/elevenlabs/ [R=301,L]

# /deepseek/privacy.html → /deepseek/
RewriteRule ^deepseek/privacy\.html$ https://banglaaiguide.com/deepseek/ [R=301,L]

# /terms/privacy/ → /privacy/
RewriteRule ^terms/privacy/?$ https://banglaaiguide.com/privacy/ [R=301,L]

# /best-ai-coding-tools-for-beginners-bangladesh/tool-detail.html?tool=cursor → /cursor/
RewriteCond %{QUERY_STRING} ^tool=cursor
RewriteRule ^best-ai-coding-tools-for-beginners-bangladesh/tool-detail\.html$ https://banglaaiguide.com/cursor/? [R=301,L]

# /ai-tools-bangladesh-bengali/tool-detail.html?tool=bolt-new → /bolt-new/
RewriteCond %{QUERY_STRING} ^tool=bolt-new
RewriteRule ^ai-tools-bangladesh-bengali/tool-detail\.html$ https://banglaaiguide.com/bolt-new/? [R=301,L]

# ============================================================
# 2. HTTPS enforcement
# ============================================================
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# ============================================================
# 3. Non-www enforcement
# ============================================================
RewriteCond %{HTTP_HOST} ^www\.banglaaiguide\.com$ [NC]
RewriteRule ^(.*)$ https://banglaaiguide.com/$1 [R=301,L]

# ============================================================
# 4. Sitewide .html → clean URL (strips .html, adds trailing slash)
#    Excludes /blog/ article pages which are served as directories
# ============================================================
RewriteCond %{REQUEST_URI} !^/blog/.*\.html$
RewriteCond %{THE_REQUEST} \ /(.+)\.html[?\ ]
RewriteRule ^ /%1/ [R=301,L]

# ============================================================
# 5. Trailing-slash normalisation (add slash to bare directory names)
# ============================================================
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !(.*)/$
RewriteRule ^(.*)$ /$1/ [R=301,L]

# Handle directory index files
DirectoryIndex index.html

# ============================================================
# GZIP Compression
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css
  AddOutputFilterByType DEFLATE text/javascript application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/ld+json
  AddOutputFilterByType DEFLATE application/xml text/xml
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE font/ttf font/otf font/woff font/woff2
</IfModule>

# ============================================================
# Browser Caching
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                          "access plus 1 month"
  ExpiresByType text/html                 "access plus 1 hour"
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType text/javascript           "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType application/json          "access plus 1 day"
  ExpiresByType image/png                 "access plus 6 months"
  ExpiresByType image/jpeg                "access plus 6 months"
  ExpiresByType image/gif                 "access plus 6 months"
  ExpiresByType image/svg+xml             "access plus 6 months"
  ExpiresByType image/webp                "access plus 6 months"
  ExpiresByType image/x-icon             "access plus 1 year"
  ExpiresByType font/woff                 "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType application/font-woff     "access plus 1 year"
  ExpiresByType application/font-woff2    "access plus 1 year"
  ExpiresByType application/xml           "access plus 1 hour"
</IfModule>

# Cache-Control headers
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=15552000"
  </FilesMatch>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

# ============================================================
# Security Headers
# ============================================================
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# Prevent directory listing
Options -Indexes
